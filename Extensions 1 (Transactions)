void AddNewClient()
{
	cout << "----------------------------------------\n";
	cout << "        Add New Clients Screen            \n";
	cout << "----------------------------------------\n";

	char AddMore = 'Y';
	do
	{
		cout << "Adding New Client : \n";
		sClient Client;
		string AccountNumber;

		cout << "Enter Account Number ? \n";
		cin >> AccountNumber;

		vector<sClient> vClients = LoadClientsFromFile(ClientsFileName);

		if (FindAccount(vClients,Client ,AccountNumber) == true)
		{
			cout << "Client with [" << AccountNumber << "] already exists, Enter another Account Number.\n";
		}
		else
		{
			Client = ReadNewClient(AccountNumber);

			fstream MyFile;
			MyFile.open(ClientsFileName, ios::out | ios::app);
			if (MyFile.is_open())
			{
				MyFile << ConvertRecordToLine(Client) << endl;
				MyFile.close();
			}
			cout << "\nClient Added Successfully.";
		}

		cout << "\n\nDo you want to add more Clients ? [Y/N]? ";
		cin >> AddMore;
	} while (toupper(AddMore) == 'Y');
}

