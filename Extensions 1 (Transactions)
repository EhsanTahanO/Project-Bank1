bool FindAccount(const vector<sClient>& vClients, sClient& Client, string AccNumberToSearch)
{
	for (const sClient& C : vClients)
	{
		if (C.AccountNumber == AccNumberToSearch)
		{
			Client = C;
			return true;
		}
	}
	return false;
}

