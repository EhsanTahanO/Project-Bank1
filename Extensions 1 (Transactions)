		cin >> Answer;
		if (Answer == 'y' || Answer == 'Y')
		{
			for (sClient& C : Clients)
			{
				if (C.AccountNumber == AccountNumber)
				{
					C = ChangeClientRecord(AccountNumber);
					break;
				}
			}
			SaveClientsDataToFile(ClientsFileName, Clients);
			cout << "\n\nClient Updated Successfully.";
			return true;
		}
	}
	else
	{
		cout << "\nClient with Account Number (" << AccountNumber << ") is Not Found!";
		return false;
	}
	return false;
}

void WithdrawTransaction()
{
	cout << "________________________________________\n";
	cout << "             Withdraw Screen: \n";
	cout << "________________________________________\n";

	sClient Client;
	vector <sClient> vClients = LoadClientsFromFile(ClientsFileName);
	double WithdrawAmount = 0;
	string AccountNumber;
	char AreSure = 'n';
	AccountNumber = ReadAccountNumber();
	while (!FindAccount(vClients, Client, AccountNumber))
	{
		cout << "Client with [" << AccountNumber << "] does not exist. \n";
		AccountNumber = ReadAccountNumber();
	}
	PrintCardClient(Client);

	cout << "\nPlease enter Withdraw ammount ? ";
	cin >> WithdrawAmount;

	while (WithdrawAmount > Client.AccountBalance)
	{
		cout << "Ammount Exceeds the balance , you can withdraw up to :"<<Client.AccountBalance<<"please enter another ammount.\n";
		cin >> WithdrawAmount;
	}

	cout << "\nAre you Sure you want to perform this transaction ? [y/n] ";
	cin >> AreSure;
	if (toupper(AreSure)=='Y')
	{
		for (sClient& Client : vClients)
		{
			if (Client.AccountNumber == AccountNumber)
			{
				Client.AccountBalance -= WithdrawAmount;
				break;
			}
		}
		SaveClientsDataToFile(ClientsFileName, vClients);
		cout << "\nDone Successfully. New balance is: " << Client.AccountBalance - WithdrawAmount;
	}
	
}

